# .env.example
# Copy this file to .env and fill in your actual API keys.
# NEVER commit .env to Git.

# 1. Anthropic Claude API — https://console.anthropic.com
ANTHROPIC_API_KEY=

# 2. Tavily Web Search — https://app.tavily.com (free: 1000 searches/month)
TAVILY_API_KEY=

# 3. LangSmith Tracing (optional but recommended) — https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=research-agent-poc
